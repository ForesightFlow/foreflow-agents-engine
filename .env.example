# ============================================================================
# foreflow-agents-engine — environment variables
# Copy to .env and fill in values.
# ============================================================================

# === Twitter Developer App credentials ===
# Create the app at https://developer.twitter.com/en/portal/projects-and-apps
# Register http://localhost:8765/callback as an OAuth callback URL.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_OAUTH_CALLBACK_URL=http://localhost:8765/callback

# ----------------------------------------------------------------------------
# Network — Polygon Amoy testnet (default) or mainnet
# ----------------------------------------------------------------------------

# Amoy testnet (default for development)
RPC_URL=https://rpc-amoy.polygon.technology
ARENA_ADDRESS=0x219937292A48266681ECf08d4c2D1B45b4517Fd2
ROUND_MANAGER=0x4e44fbAD7a1DaF5E42Dcc7fb48426Ff71785Da08

# Polygon mainnet (uncomment for production):
# RPC_URL=https://polygon-bor-rpc.publicnode.com
# ARENA_ADDRESS=0xB81e4F6D37f036508F584B8e9Cc1dceA096D554d
# ROUND_MANAGER=0x2FA165234ba5fE0bA309853c3fa2Df9949F867Cf
# CHAIN_ID=137

# Free public RPC options for mainnet (no key required):
#   https://polygon-bor-rpc.publicnode.com
#   https://polygon.drpc.org
#   https://polygon-mainnet.public.blastapi.io
# Paid options (recommended for production):
#   Alchemy: https://polygon-mainnet.g.alchemy.com/v2/<KEY>
#   Infura:  https://polygon-mainnet.infura.io/v3/<KEY>

# CHAIN_ID=80002   # 80002=Amoy testnet, 137=Polygon mainnet

# ----------------------------------------------------------------------------
# Subgraph access
# ----------------------------------------------------------------------------

# Studio URL (free, rate-limited; default when THEGRAPH_API_KEY+SUBGRAPH_ID not set)
SUBGRAPH_URL=https://api.studio.thegraph.com/query/1745354/foresight-arena/version/latest

# Authenticated gateway (recommended for production — higher rate limits)
# Get API key at https://thegraph.com/studio/apikeys/
# SUBGRAPH_ID is the hex deployment ID from the Graph Network Explorer or Studio dashboard.
# When both are set, SUBGRAPH_URL above is ignored and the engine builds:
#   https://gateway.thegraph.com/api/<THEGRAPH_API_KEY>/subgraphs/id/<SUBGRAPH_ID>
THEGRAPH_API_KEY=
SUBGRAPH_ID=4ybnvA1cDQjRRm1YzhBhaeVAn7XrQFGP9GL44RvwPvx8

# RELAYER_URL=https://api.foresightarena.xyz

# ----------------------------------------------------------------------------
# Etherscan v2 unified API — backup balance read for healthcheck
# ----------------------------------------------------------------------------
# Despite the etherscan.io domain, this supports Polygon via chainid=137 parameter.
# Used as fallback if the primary RPC endpoint is unavailable or returns 4xx/5xx.
FFLOW_POLYGONSCAN_API_KEY=
FFLOW_POLYGONSCAN_URL=https://api.etherscan.io/v2/api

# ----------------------------------------------------------------------------
# Agent code location
# ----------------------------------------------------------------------------

# Path to the foreflow-agents repo (must be built: npm run build inside it)
# Defaults to ../foreflow-agents relative to the engine root.
# FOREFLOW_AGENTS_DIR=/opt/foreflow/foreflow-agents

# ----------------------------------------------------------------------------
# Dry-run mode
# ----------------------------------------------------------------------------

# DRY_RUN=1 prevents any on-chain transactions and skips wallet key checks.
# Remove or set to 0 for live operation.
DRY_RUN=1

# ----------------------------------------------------------------------------
# Per-agent private keys — written here after register-all
# ----------------------------------------------------------------------------

FOREFLOW_ENSEMBLE_AGENT_KEY=0x...
FOREFLOW_DEBATE_AGENT_KEY=0x...
FOREFLOW_ORCHESTRATOR_AGENT_KEY=0x...
FOREFLOW_PIPELINE_AGENT_KEY=0x...
FOREFLOW_CONSENSUS_AGENT_KEY=0x...

# ----------------------------------------------------------------------------
# foreflow-agents operational config (passed through to agent subprocess)
# ----------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
